<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#111827" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <link rel="icon" type="image/png" sizes="180x180" href="~/icons/apple-touch-icon.png" asp-append-version="true" />
    <link rel="shortcut icon" type="image/png" href="~/icons/apple-touch-icon.png" asp-append-version="true" />
    <link rel="apple-touch-icon" sizes="180x180" href="~/icons/apple-touch-icon.png" asp-append-version="true" />
    <title>Scanner System</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="manifest" href="~/manifest.webmanifest" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    @RenderBody()

    @* Modal must render after page content so it stacks above the app (z-index + paint order). *@
    @if (Context.User?.Identity?.IsAuthenticated == true)
    {
        @await Html.PartialAsync("_ScannerOperatorPrompt")
    }

    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').catch(() => {
                });
            });
        }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
